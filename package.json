{
  "name": "openpolotno",
  "version": "1.0.0",
  "description": "Open-source alternative to Polotno with full template and API support.",
  "author": "Rutvik Panchal",
  "license": "MIT",
  "keywords": [
    "openpolotno",
    "polotno",
    "design editor",
    "canvas editor",
    "photo editor",
    "react design tool",
    "template editor",
    "konva",
    "open source"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/therutvikp/OpenPolotno.git"
  },
  "homepage": "https://github.com/therutvikp/OpenPolotno#readme",
  "bugs": {
    "url": "https://github.com/therutvikp/OpenPolotno/issues"
  },
  "files": [
    "dist",
    "src",
    "LICENSE",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/raeditor-app.js",
  "module": "./dist/raeditor-app.js",
  "types": "./dist/raeditor-app.d.ts",
  "exports": {
    ".": {
      "import": "./dist/raeditor-app.js",
      "types": "./dist/raeditor-app.d.ts"
    },
    "./*": {
      "import": "./dist/*.js",
      "types": "./dist/*.d.ts"
    },
    "./side-panel/*": {
      "import": "./dist/side-panel/*.js",
      "types": "./dist/side-panel/*.d.ts"
    },
    "./side-panel": {
      "import": "./dist/side-panel/side-panel.js",
      "types": "./dist/side-panel/side-panel.d.ts"
    },
    "./canvas/*": {
      "import": "./dist/canvas/*.js",
      "types": "./dist/canvas/*.d.ts"
    },
    "./model/*": {
      "import": "./dist/model/*.js",
      "types": "./dist/model/*.d.ts"
    },
    "./pages-timeline/*": {
      "import": "./dist/pages-timeline/*.js",
      "types": "./dist/pages-timeline/*.d.ts"
    },
    "./pages-timeline": {
      "import": "./dist/pages-timeline/pages-timeline.js",
      "types": "./dist/pages-timeline/pages-timeline.d.ts"
    },
    "./utils/*": {
      "import": "./dist/utils/*.js",
      "types": "./dist/utils/*.d.ts"
    },
    "./toolbar/*": {
      "import": "./dist/toolbar/*.js",
      "types": "./dist/toolbar/*.d.ts"
    },
    "./toolbar": {
      "import": "./dist/toolbar/toolbar.js",
      "types": "./dist/toolbar/toolbar.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@blueprintjs/core": "5.19.0",
    "@blueprintjs/icons": "^5.23.0",
    "@blueprintjs/select": "5.3.20",
    "@meronex/icons": "^4.0.0",
    "cssom": "^0.5.0",
    "dompurify": "^3.3.3",
    "fast-json-patch": "^3.1.1",
    "functions-have-names": "^1.2.3",
    "gifuct-js": "^2.1.2",
    "gradient-parser": "^1.1.1",
    "konva": "^10.0.4",
    "mensch": "^0.3.4",
    "mobx": "6.13.7",
    "mobx-react-lite": "^4.1.0",
    "mobx-state-tree": "6.0.1",
    "nanoid": "3.3.4",
    "quill": "^1.3.7",
    "rasterizehtml": "^1.3.1",
    "react": "^18.2.0",
    "react-color": "^2.19.3",
    "react-dom": "^18.2.0",
    "react-konva": "^19.2.3",
    "react-konva-utils": "^2.0.0",
    "react-sortablejs": "6.1.4",
    "react-window": "^1.8.11",
    "sortablejs": "^1.15.6",
    "svg-round-corners": "^0.4.3",
    "swr": "^2.3.4",
    "use-image": "^1.1.4"
  },
  "peerDependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/dompurify": "^3.0.5",
    "@types/node": "^25.5.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.0",
    "glob": "^13.0.6",
    "tsup": "^8.0.0",
    "typescript": "^5.8.3"
  },
}
